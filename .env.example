# Azure OpenAI — hackathon resource (East US 2)
# GPT-5.x uses the Responses API (/openai/v1/), not chat completions.
AZURE_OPENAI_ENDPOINT=https://openai-eus2-hackathon.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-5.3-chat
AZURE_OPENAI_DEPLOYMENT_FRONTIER=gpt-5.3-chat

# App
DATABASE_URL=sqlite+aiosqlite:///./data/catalog.db
STORE_NAME=Catalogsmith Demo Shop
CHROMA_HOST=chroma
CHROMA_PORT=8000

# Set to 1 for offline dev/tests (heuristic parser + mock draft)
LLM_MOCK=0
CHROMA_EPHEMERAL=0

# Set to 1 to disable feedback memory retrieval/storage (ablation OFF arm)
MEMORY_OFF=0

# MCP storefront transport for publish path (inline | stdio)
MCP_MODE=inline
